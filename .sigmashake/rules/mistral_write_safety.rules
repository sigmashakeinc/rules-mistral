# mistral_write_safety.rules
# Technology: mistral | Capability: write

rule mistral-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "api_key="
  MESSAGE "Blocked an unsafe pattern in mistral. Use the recommended best practices for 2025/2026."
}

rule mistral-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "mistral.client"
  MESSAGE "You are using an outdated API for mistral. Please upgrade to the newer API."
}
